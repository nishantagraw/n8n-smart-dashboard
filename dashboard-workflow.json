    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst b = input.body || input;\nconst date = b.date || '2026-01-01';\nconst time = b.time || '09:00';\nconst endTime = b.endTime || '10:00';\nconst endDate = b.endDate || date;\nconst startUTC = new Date(date + 'T' + time + ':00+05:30').toISOString();\nconst endUTC = new Date(endDate + 'T' + endTime + ':00+05:30').toISOString();\nreturn [{ json: {\n  start: startUTC,\n  end: endUTC,\n  title: b.title || 'Event',\n  description: b.description || '',\n  location: b.location || ''\n}}];"
      },
      "id": "d1000001-0015-4015-8015-000000000015",
      "name": "Prepare Calendar Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        200
      ]
    },
    {
      "parameters": {
        "resource": "event",
        "operation": "create",
        "calendar": {
          "__rl": true,
          "mode": "list",
          "value": "primary"
        },
        "start": "={{ $json.start }}",
        "end": "={{ $json.end }}",
        "additionalFields": {
          "summary": "={{ $json.title }}",
          "description": "={{ $json.description }}",
          "location": "={{ $json.location }}"
        }
      },
      "id": "d1000001-0005-4005-8005-000000000005",
      "name": "Create Calendar Event",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.2,
      "position": [
        680,
        200
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "prkT6e3bbfS3cg5M",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst b = input.body || input;\nconst now = new Date().toISOString();\nreturn [{ json: {\n  Timestamp: now,\n  Name: b.name || '',\n  Phone: b.phone || '',\n  Category: b.category || '',\n  Amount: b.amount || '',\n  Notes: b.notes || ''\n}}];"
      },
      "id": "d1000001-0006-4006-8006-000000000006",
