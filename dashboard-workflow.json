      "id": "d1000001-0008-4008-8008-000000000008",
      "name": "Send Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        680,
        800
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "QO3PmTvJirU8XMgq",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst b = input.body || input;\nlet binary;\n\nif (b.fileData && b.fileData.startsWith('data:')) {\n  const parts = b.fileData.split(',');\n  const meta = parts[0];\n  const base64Data = parts[1];\n  const mimeMatch = meta.match(/data:(.*?);/);\n  const mimeType = mimeMatch ? mimeMatch[1] : 'application/octet-stream';\n  const ext = mimeType.split('/')[1] || 'bin';\n  const fileName = b.fileName || ('upload.' + ext);\n  binary = { data: { data: base64Data, mimeType: mimeType, fileName: fileName, fileExtension: ext } };\n} else {\n  const content = b.content || b.notes || 'Empty note';\n  const buffer = Buffer.from(content, 'utf-8');\n  const fileName = (b.fileName || 'note') + '.txt';\n  binary = { data: { data: buffer.toString('base64'), mimeType: 'text/plain', fileName: fileName, fileExtension: 'txt' } };\n}\n\nreturn [{ json: { fileName: b.fileName || 'upload', folder: b.folder || '' }, binary: binary }];"
      },
