        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleSheetsOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"values\": [\n    [\n      \"{{$json.Timestamp}}\",\n      \"{{$json.Name}}\",\n      \"{{$json.Phone}}\",\n      \"{{$json.Category}}\",\n      \"{{$json.Amount}}\",\n      \"{{$json.Notes}}\"\n    ]\n  ]\n}",
